[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
lap = "==0.5.12"
tqdm = "==4.67.1"
scipy = "==1.15.3"
tabulate = "==0.9.0"
fvcore = "==0.1.5.post20221221"
iopath = "==0.1.9"
shapely = "==2.0.7"
h5py = "==3.16.0"
jsonschema = "==4.23.0"
boto3 = "==1.36.2"
python-dotenv = "==1.0.1"
pytz = "==2024.2"
requests = "==2.32.3"
pandas = "==2.3.3"  # used by datasets.cloud_utils.upload_utils (base) + eval.tracking.algo

# Promoted to direct deps: spatialai_data_utils imports these directly
# (visualization, calibration, geometry). They previously arrived only as
# transitive deps of nuscenes-devkit, which is now an opt-in extra (below), so
# they must be declared explicitly to survive its removal from the lock.
matplotlib = "==3.11.0"
pyquaternion = "==0.9.9"
scikit-learn = "==1.9.0"
pycocotools = "==2.0.11"
pillow = "==12.2.0"

# Pinned explicitly so numpy is identical across ALL install options. The
# `eval` extra (nuscenes-devkit) caps numpy<2.0.0; without this pin the base /
# `viz` install would float to numpy 2.x and diverge from the eval/full +
# locked set (matches v2.0.0, where nuscenes was mandatory and numpy was 1.26.4).
numpy = "==1.26.4"

# nuscenes-devkit is an OPTIONAL dependency, deliberately NOT declared here
# (and removed from Pipfile.lock). Dropping it keeps the default install and
# the locked dependency set free of OpenCV, which nuscenes-devkit pulls
# transitively (opencv-python-headless) and which bundles ffmpeg (flagged by
# OSRB). NOTE: the eval subpackage (detection mAP / tracking / HOTA / AICity
# MTMC) and core.boxes.aicity_box subclass nuscenes classes at import time, so
# they REQUIRE nuscenes and cannot be imported without it. motmetrics is also
# eval-only (used by eval.tracking.algo via nuscenes.eval.tracking, and not
# declared by nuscenes-devkit), so it lives in the same `eval` extra rather than
# in the base packages above. Install them via the wheel's `eval` extra (which
# also brings opencv):
#   pip install 'spatialai-data-utils[eval]'
# nuscenes-devkit = "==1.2.0"
# motmetrics = "==1.4.0"

# torch and pytorch3d are required at runtime but cannot be managed by pipenv:
# - torch needs a specific CUDA variant chosen at install time
# - pytorch3d requires torch at build time (--no-build-isolation)
# Install manually (pick ONE torch variant, then pytorch3d):
#   CPU:    pip install torch>=2.10.0 --index-url https://download.pytorch.org/whl/cpu
#   CUDA:   pip install torch>=2.10.0
#   pip install 'pytorch3d @ git+https://github.com/facebookresearch/pytorch3d.git@33824be' --no-build-isolation
# torch = ">=2.10.0"
# pytorch3d = {git = "https://github.com/facebookresearch/pytorch3d.git", ref = "33824be"}

# opencv (cv2) is an OPTIONAL runtime dependency, deliberately NOT declared
# here (and removed from Pipfile.lock) so the published wheel / locked
# dependency set does not ship the OpenCV distribution, which bundles ffmpeg
# (flagged by OSRB). It is only needed by the visualization / video code paths
# (spatialai_data_utils.visualization, tools/video_utils); those raise a clear
# ImportError with install instructions at call time when it is missing
# (see spatialai_data_utils.utils.optional_dependencies.import_cv2).
# Install the `viz` extra only if you need those features (brings a headless
# OpenCV build): pip install 'spatialai-data-utils[viz]'
# opencv-python-headless = ">=4.5.4.58,<=4.11.0.86"

[dev-packages]
pytest = "==9.0.3"

[requires]
python_version = "3.13"
