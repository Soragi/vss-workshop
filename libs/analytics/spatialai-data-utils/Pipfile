# torch and pytorch3d are required at runtime but cannot be managed by pipenv:
# - torch needs a specific CUDA variant chosen at install time
# - pytorch3d requires torch at build time (--no-build-isolation)
# Install manually (pick ONE torch variant, then pytorch3d):
#   CPU:    pip install torch>=2.10.0 --index-url https://download.pytorch.org/whl/cpu
#   CUDA:   pip install torch>=2.10.0
#   pip install 'pytorch3d @ git+https://github.com/facebookresearch/pytorch3d.git@33824be' --no-build-isolation
# torch = ">=2.10.0"
# pytorch3d = {git = "https://github.com/facebookresearch/pytorch3d.git", ref = "33824be"}

[dev-packages]
pytest = "==9.0.3"

[requires]
python_version = "3.13"
