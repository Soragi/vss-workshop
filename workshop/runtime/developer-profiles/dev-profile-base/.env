# VSS 3.2.1 Base workshop defaults. The deployment script copies this file to
# a private state directory and fills in the machine-specific values.
MODE=2d
BP_PROFILE=bp_developer_base
HARDWARE_PROFILE=RTXPRO6000BW
LLM_DEVICE_ID=0
VLM_DEVICE_ID=1
LLM_MODE=local
VLM_MODE=local
LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2
LLM_MODEL_TYPE=nim
LLM_ENV_FILE=
LLM_BASE_URL=
VLM_NAME=nvidia/cosmos3-nano-reasoner
VLM_NAME_SLUG=cosmos3-reasoner
VLM_MODEL_TYPE=nim
VLM_ENV_FILE=
VLM_BASE_URL=
NIM_MODEL_SIZE=nano
VLM_NIM_KVCACHE_PERCENT=0.7
VLM_NIM_MODEL_NAME=
COMPOSE_PROFILES=bp_developer_base_2d,bp_developer_base_2d_RTXPRO6000BW,llm_local_nvidia-nemotron-nano-9b-v2,vlm_local_cosmos3-reasoner
VSS_APPS_DIR=/path/to/workshop/runtime
VSS_DATA_DIR=/path/to/vss-workshop-data
HOST_IP=127.0.0.1
EXTERNAL_IP=127.0.0.1
HAPROXY_PORT=7777
VSS_PUBLIC_HTTP_PROTOCOL=http
VSS_PUBLIC_WS_PROTOCOL=ws
VSS_PUBLIC_HOST=127.0.0.1
VSS_PUBLIC_PORT=7777
NGC_CLI_API_KEY=
COMPOSE_PROJECT_NAME=vssworkshop
LLM_PORT=30081
VLM_PORT=30082
VSS_AGENT_VERSION=3.2.1
VSS_AGENT_CONFIG_FILE=/vss-agent/deploy/docker/developer-profiles/dev-profile-base/vss-agent/configs/config.yml
VSS_AGENT_HOST=0.0.0.0
VSS_AGENT_PORT=8000
ENABLE_AUDIO=false
INSTALL_PROPRIETARY_CODECS=true
VST_PORT=30888
VST_EXTERNAL_URL=http://127.0.0.1:7777
VST_INTERNAL_URL=http://127.0.0.1:30888
VST_STREAM_PROCESSOR_IMAGE_TAG=3.2.1
VST_SENSOR_IMAGE_TAG=3.2.1
VST_INGRESS_IMAGE_TAG=3.2.1
VST_NGINX_MODE=vst-direct
VSS_AGENT_OBJECT_STORE_TYPE=local_object_store
VSS_AGENT_REPORTS_BASE_URL=http://127.0.0.1:7777/static/
VSS_AGENT_EXTERNAL_URL=http://127.0.0.1:7777
VSS_AGENT_TEMPLATE_PATH=
VSS_AGENT_TEMPLATE_NAME=
PHOENIX_ENDPOINT=http://127.0.0.1:6006
# These string values are required by the VSS Agent schema even though the
# workshop does not ship or run the optional evaluation workflow.
EVAL_LLM_JUDGE_NAME=nvidia/nvidia-nemotron-nano-9b-v2
EVAL_LLM_JUDGE_BASE_URL=http://127.0.0.1:30081
EVAL_DIR=/vss-agent/agent_eval
DATASET_DIR=/vss-agent/agent_eval/dataset/vss-devx-base
DATASET_FILE_NAME=dataset_single_turn.json
EVAL_OUTPUT_DIR=/vss-agent/agent_eval/results
REPORT_REFERENCE_BASE_DIR=/vss-agent/agent_eval/dataset/vss-devx-base/gt
NEXT_PUBLIC_APP_TITLE=VSS AI Advisor Workshop
NEXT_PUBLIC_APP_SUBTITLE=Vision Search and Summarization
NEXT_PUBLIC_ENABLE_CHAT_TAB=false
NEXT_PUBLIC_ENABLE_CHAT_SIDEBAR=true
# Workshop layout: keep the contextual VSS Agent ready on the left, with
# Video Management (including Upload Video) available in the main panel.
NEXT_PUBLIC_CHAT_SIDEBAR_OPEN_DEFAULT=true
NEXT_PUBLIC_SIDEBAR_CHAT_SIDE_CHATBAR_COLLAPSED=false
NEXT_PUBLIC_SIDEBAR_CHAT_WORKFLOW=VSS Agent
NEXT_PUBLIC_SIDEBAR_CHAT_CHAT_UPLOAD_FILE_ENABLE=true
NEXT_PUBLIC_SIDEBAR_CHAT_WEB_SOCKET_DEFAULT_ON=true
# Intermediate steps are useful for developers but distract from a workshop
# conversation, so leave the agent panel focused on answers and video Q&A.
NEXT_PUBLIC_SIDEBAR_CHAT_ENABLE_INTERMEDIATE_STEPS=false
NEXT_PUBLIC_ENABLE_ALERTS_TAB=false
NEXT_PUBLIC_ENABLE_SEARCH_TAB=false
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=false
NEXT_PUBLIC_ENABLE_MAP_TAB=false
NEXT_PUBLIC_ENABLE_VIDEO_MANAGEMENT_TAB=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_VIDEO_UPLOAD_ENABLE=true
NEXT_PUBLIC_VIDEO_MANAGEMENT_TAB_ADD_RTSP_ENABLE=false
