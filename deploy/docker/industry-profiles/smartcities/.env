# =============================================================================
# SMARTCITIES OVERLAY
# =============================================================================
# This file contains ONLY the keys where the smartcities industry profile
# differs from developer-profiles/dev-profile-alerts/.env (overrides) or
# introduces new variables (additions). All identical keys live in the
# dev-profile-alerts/.env base and are inherited from there.
#
# Merge order: load dev-profile-alerts/.env first, then this file second so
# these values take precedence.
# =============================================================================

# =============================================================================
# OVERRIDES (key exists in dev-profile-alerts/.env with a different value)
# =============================================================================

MODE=2d_cv

# Blueprint profile: bp_developer_alerts
BP_PROFILE=bp_developer_alerts

# Perception 2D model: smartcities uses RTDETR (alerts uses GDINO).
MODEL_NAME_2D="RTDETR"

# Number of sensors/streams to process (alerts default is 1).
NUM_SENSORS=10

# UI branding and feature toggles for the smartcities experience.
NEXT_PUBLIC_APP_SUBTITLE="Smart Cities"
NEXT_PUBLIC_SIDEBAR_CHAT_WORKFLOW="Smart Cities Agent"
NEXT_PUBLIC_SIDEBAR_CHAT_CHAT_UPLOAD_FILE_ENABLE=true
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=true
NEXT_PUBLIC_ENABLE_MAP_TAB=true

# =============================================================================
# ADDITIONS (keys not present in dev-profile-alerts/.env)
# =============================================================================

# Eval LLM judge endpoint (used by smartcities agent evaluation flows).
EVAL_LLM_JUDGE_NAME=${LLM_NAME}
EVAL_LLM_JUDGE_BASE_URL=http://${HOST_IP}:${LLM_PORT}

# Explicit RTVI VLM port (alerts hardcodes 8018 in RTVI_VLM_BASE_URL/ENDPOINT;
# smartcities exposes it as a variable for reuse).
RTVI_VLM_PORT=8018

# Direct streamprocessing (no SDR/Envoy/SDRC router on :10000).
STREAM_PROCESSOR_MODULE_ENDPOINT=http://localhost:30001
VST_NGINX_MODE=vst-direct

# VST Image tags for common all platforms
VST_STREAM_PROCESSOR_IMAGE_TAG="3.2.1"
VST_SENSOR_IMAGE_TAG="3.2.1"
NVSTREAMER_IMAGE_TAG="3.2.1"
VST_INGRESS_IMAGE_TAG="3.2.1"

# Video Analytics UI app selector (its = Intelligent Transportation System view).
VIDEO_ANALYTICS_UI_APP_NAME=its

# Google Maps API key for the smartcities Map tab.
GOOGLE_MAPS_API_KEY=''

# Video DATA DIR
NVSTREAMER_VIDEO_DIR='vss-nvstreamer-video-dir'

# ANALYTICS CONTAINER IMAGE TAGS
VIDEO_ANALYTICS_UI_IMAGE_TAG="3.2.1"
CALIBRATION_TOOLKIT_IMAGE_TAG="3.2.1"

# Disable Kafka messages
RTVI_VLM_KAFKA_ENABLED=false
